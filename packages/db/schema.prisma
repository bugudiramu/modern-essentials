// Week 1 Prisma Schema for Modern Essentials
// Tables: users, products, orders, inventory_batches, webhook_events
// Week 4 Addition: subscriptions, subscription_events, ledger_entries

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Core user identity - phone is primary login in India
model User {
  id        String   @id @default(cuid())
  phone     String   @unique // Primary login in India
  email     String?  @unique
  clerkId   String   @unique @map("clerk_id")
  tier      UserTier @default(FREE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  orders       Order[]
  carts        Cart[]
  subscriptions Subscription[]
  ledgerEntries LedgerEntry[]

  @@map("users")
}

enum UserTier {
  FREE
  MEMBER
}

// Product catalog - Base product for marketing and grouping
model Product {
  id         String      @id @default(cuid())
  name       String
  category   Category
  isActive   Boolean     @default(true) @map("is_active")
  images     ProductImage[]
  description String?     // SEO and product description
  seoTitle   String?     @map("seo_title") // SEO meta title
  seoDesc     String?     @map("seo_desc") // SEO meta description
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  // Relations
  variants     ProductVariant[]
  partnerLinks ProductPartnerLink[]

  @@map("products")
}

// Product variants (e.g. 6 pack, 12 pack, 24 pack)
model ProductVariant {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  sku        String   @unique // Stock keeping unit
  packSize   Int      @map("pack_size") // e.g. 6, 12
  price      Int      // Price in paise (Rs 100 = 10000)
  subPrice   Int      @map("sub_price") // Subscription price (discounted)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  product          Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryBatches InventoryBatch[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  subscriptions    Subscription[]
  subscriptionItems SubscriptionItem[]
  subscriptionPlans SubscriptionPlan[]

  @@map("product_variants")
}

// Partner links for Quick Commerce
model ProductPartnerLink {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  partner   Partner
  url       String
  isActive  Boolean  @default(true) @map("is_active")

  // Relations
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, partner])
  @@map("product_partner_links")
}

enum Partner {
  ZEPTO
  BLINKIT
  INSTAMART
  FLIPKART
}

enum Category {
  REGULAR_EGGS
  BROWN_EGGS
  HIGH_PROTEIN_EGGS
}

// Product images for Cloudflare R2 CDN
model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String   // Cloudflare R2 CDN URL
  alt       String?  // Alt text for accessibility
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_images")
}

// FEFO inventory tracking - First Expired, First Out
// Critical for perishables - ORDER BY expires_at ASC on every pick
model InventoryBatch {
  id          String        @id @default(cuid())
  variantId   String        @map("variant_id")
  qty         Int           // Current quantity
  receivedAt  DateTime      @map("received_at")
  expiresAt   DateTime      @map("expires_at") // FEFO sort key
  locationId  String?       @map("location_id") // Warehouse bin location
  status      BatchStatus   @default(AVAILABLE)
  qcStatus    QCStatus      @default(PENDING) @map("qc_status")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  farmBatch   FarmBatch?
  wastageLogs WastageLog[]

  @@index([variantId, expiresAt]) // FEFO pick index
  @@index([status, expiresAt])
  @@map("inventory_batches")
}

enum BatchStatus {
  AVAILABLE
  RESERVED
  DISPATCHED
  WASTAGE
}

enum QCStatus {
  PENDING
  PASSED
  QUARANTINE
  REJECTED
}

// Farm registry for sourcing traceability
model Farm {
  id           String      @id @default(cuid())
  name         String
  location     String
  contactName  String?     @map("contact_name")
  contactPhone String?     @map("contact_phone")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // Relations
  batches      FarmBatch[]

  @@map("farms")
}

// Links farm supply to warehouse batch
model FarmBatch {
  id                  String   @id @default(cuid())
  farmId              String   @map("farm_id")
  variantId           String   @map("variant_id")
  inventoryBatchId    String   @unique @map("inventory_batch_id")
  qtyCollected        Int      @map("qty_collected")
  collectedAt         DateTime @map("collected_at")
  qcStatus            QCStatus @default(PENDING) @map("qc_status")
  temperatureOnArrival Float?   @map("temperature_on_arrival")
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  farm           Farm           @relation(fields: [farmId], references: [id])
  inventoryBatch InventoryBatch @relation(fields: [inventoryBatchId], references: [id])

  @@map("farm_batches")
}

// Audit trail for every unit written off
model WastageLog {
  id               String        @id @default(cuid())
  variantId        String        @map("variant_id")
  inventoryBatchId String?       @map("inventory_batch_id")
  qty              Int
  reason           WastageReason
  loggedBy         String        @map("logged_by") // Clerk ID or name
  notes            String?
  loggedAt         DateTime      @default(now()) @map("logged_at")

  // Relations
  inventoryBatch InventoryBatch? @relation(fields: [inventoryBatchId], references: [id])

  @@map("wastage_logs")
}

enum WastageReason {
  BREAKAGE_PACKING
  BREAKAGE_TRANSIT
  QC_REJECTED
  EXPIRED
  CUSTOMER_RETURN
  OTHER
}

// Order tracking - both one-time and subscription renewals
model Order {
  id             String      @id @default(cuid())
  userId         String      @map("user_id")
  subscriptionId String?     @map("subscription_id") // Null for one-time orders
  razorpayOrderId String?    @unique @map("razorpay_order_id")
  status         OrderStatus @default(PENDING)
  type           OrderType
  total          Int         // Total in paise
  
  // Delivery Address
  addressLine1   String?     @map("address_line_1")
  addressLine2   String?     @map("address_line_2")
  city           String?
  state          String?
  postalCode     String?     @map("postal_code")
  
  placedAt       DateTime    @default(now()) @map("placed_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  items        OrderItem[]

  @@index([userId, placedAt])
  @@index([status, placedAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PAYMENT_FAILED
  PICKED
  PACKED
  DISPATCHED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderType {
  ONE_TIME
  SUBSCRIPTION_RENEWAL
}

// Order line items
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  variantId String   @map("variant_id")
  qty       Int
  price     Int    // Price at time of order (in paise)
  total     Int    // price * qty

  // Relations
  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

// Week 4: Subscription System
model Subscription {
  id                String              @id @default(cuid())
  userId             String
  variantId          String             @map("variant_id")
  planId             String?            @map("plan_id")
  razorpaySubscriptionId String?        @unique @map("razorpay_subscription_id")
  quantity           Int                  // packs per delivery
  frequency          SubscriptionFrequency  @default(WEEKLY)
  status             SubscriptionStatus   @default(ACTIVE)
  addressLine1       String?              @map("address_line_1")
  addressLine2       String?              @map("address_line_2")
  city               String?
  state              String?
  postalCode         String?              @map("postal_code")
  nextBillingAt      DateTime             @default(now()) // when next payment should be generated
  nextDeliveryAt     DateTime             @default(now()) @map("next_delivery_at") // when next delivery should happen
  pauseUntil         DateTime?            @map("pause_until")
  skipCount          Int                  @default(0) @map("skip_count")
  dunningAttempt     Int                  @default(0) @map("dunning_attempt")
  dunningStartedAt   DateTime?            @map("dunning_started_at")
  cancelReason       String?              @map("cancel_reason")
  cancelledAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Relations
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant    ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  plan       SubscriptionPlan? @relation(fields: [planId], references: [id])
  items      SubscriptionItem[]
  events      SubscriptionEvent[]
  logs       SubscriptionLog[]
  orders     Order[]

  @@index([userId, status])
  @@map("subscriptions")
}

model SubscriptionLog {
  id             String   @id @default(cuid())
  subscriptionId String   @map("subscription_id")
  action         String
  oldValue       String?  @map("old_value")
  newValue       String?  @map("new_value")
  reason         String?
  performedBy    String   @map("performed_by") // user ID or "system"
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_logs")
}

model SubscriptionPlan {
  id              String                @id @default(cuid())
  variantId       String                @map("variant_id")
  frequency       SubscriptionFrequency
  amount          Int                   // in paise
  durationMonths  Int                   @default(1) @map("duration_months") // 1, 2, 3
  billingCycles   Int?                  @map("billing_cycles") // e.g. 12 for 3-months weekly
  razorpayPlanId  String                @unique @map("razorpay_plan_id")
  isActive        Boolean               @default(true) @map("is_active")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  // Relations
  variant         ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  subscriptions   Subscription[]

  @@unique([variantId, frequency, amount, durationMonths])
  @@map("subscription_plans")
}

enum SubscriptionFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAUSED
  RENEWAL_DUE
  DUNNING
  CANCELLED
  EXPIRED
}

model SubscriptionItem {
  id             String   @id @default(cuid())
  subscriptionId String   @map("subscription_id")
  variantId      String   @map("variant_id")
  quantity       Int
  price          Int       // subscription price in paise
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  subscription Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("subscription_items")
}

model SubscriptionEvent {
  id             String                @id @default(cuid())
  subscriptionId  String
  eventType      SubscriptionEventType
  description    String?
  metadata       Json?                 // additional event data
  createdAt      DateTime              @default(now())

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_events")
}

enum SubscriptionEventType {
  CREATED
  ACTIVATED
  UPDATED
  PAUSED
  RESUMED
  CANCELLED
  EXPIRED
  PAYMENT_FAILED
  RENEWED
}

// Week 4: Rewards Ledger System
model LedgerEntry {
  id        String   @id @default(cuid())
  userId     String
  type       LedgerEntryType
  points     Int       // can be positive (earn) or negative (spend)
  description String
  metadata   Json?     // additional context
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ledger_entries")
}

enum LedgerEntryType {
  EARN
  SPEND
}

// Webhook event log - idempotency key: (provider, event_id)
// Every handler MUST check this table before processing
model WebhookEvent {
  id           String    @id @default(cuid())
  provider     String    // e.g., 'razorpay', 'interakt', 'shadowfax'
  eventId     String    @map("event_id") // Provider's event ID
  eventType    String    @map("event_type") // e.g., 'payment.captured'
  processed    Boolean   @default(false)
  data         Json     // full webhook payload
  processedAt  DateTime? @map("processed_at") // Null = not yet processed
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([provider, eventId]) // Idempotency constraint
  @@index([provider, eventType])
  @@map("webhook_events")
}

// Shopping cart system for user orders
model Cart {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@unique([userId]) // One cart per user
  @@map("carts")
}

// Individual items in a user's cart
model CartItem {
  id            String   @id @default(cuid())
  cartId        String   @map("cart_id")
  variantId     String   @map("variant_id")
  quantity      Int
  priceSnapshot Int      @map("price_snapshot") // Price at time of adding (in paise)
  isSubscription Boolean  @default(false) @map("is_subscription")
  frequency     SubscriptionFrequency?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId, isSubscription]) // Allow same product as both one-time and sub
  @@map("cart_items")
}