{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@modern-essentials/db": ["./packages/db"],
      "@modern-essentials/types": ["./packages/types"],
      "@modern-essentials/utils": ["./packages/utils"],
      "@modern-essentials/email": ["./packages/email"],
      "@modern-essentials/ui": ["./packages/ui"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "build"]
}
